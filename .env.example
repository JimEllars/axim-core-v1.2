# Supabase connection details
VITE_SUPABASE_URL="YOUR_SUPABASE_URL"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# Default login credentials for the seed user (see setup.sql)
# Email: admin@example.com
VITE_LOGIN_PASSWORD="axim2024secure"

# Set to "true" to use a mock LLM for testing without API keys
VITE_MOCK_LLM_ENABLED="true"

# Application Mode
# Determines if the app runs in "electron" mode or "cloud" mode for web deployment
VITE_APP_MODE="electron"

# External API Configuration
# These are used in the Electron main process and should not be prefixed with VITE_
APIX_DRIVE_URL="YOUR_APIX_DRIVE_URL"
APIX_DRIVE_API_KEY="YOUR_APIX_DRIVE_API_KEY"
AXIM_CORE_URL="YOUR_AXIM_CORE_URL"
AXIM_CORE_API_KEY="YOUR_AXIM_CORE_API_KEY"
ONYX_AI_URL="YOUR_ONYX_AI_URL"
ONYX_AI_API_KEY="YOUR_ONYX_AI_API_KEY"

# Chatbase Agent IDs (for AXiM Core Agents)
# These IDs are used to route requests to specific Chatbase agents.
# You can find these IDs in your Chatbase dashboard.
VITE_CHATBOT_ID_CTO="YOUR_CHATBOT_ID_CTO"
VITE_CHATBOT_ID_CFO="YOUR_CHATBOT_ID_CFO"
VITE_CHATBOT_ID_MANAGER="YOUR_CHATBOT_ID_MANAGER"

# Data Source Selection
# Determines the primary data source for the application.
# Valid options are "supabase" or "gcp".
VITE_DATA_SOURCE="supabase"

# Base URL for the AXiM Core GCP Backend
VITE_API_BASE_URL="http://localhost:8080"

# Stripe Configuration
# The Price ID for the Pro subscription plan
VITE_STRIPE_PRICE_ID_PRO="price_1234567890"
