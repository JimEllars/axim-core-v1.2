{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "axim-core-dashboard",
  "compatibility_date": "2026-07-09",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  }
}
