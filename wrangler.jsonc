{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "axim-core-worker",
  "main": "cloudflare-workers/src/index.js",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "dist/client"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
