{
  "name": "axim-core-cloudflare-workers",
  "version": "1.0.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "description": "Cloudflare Workers for AXiM Core Edge Network Integration",
  "main": "src/index.js",
  "scripts": {
    "build": "echo 'No build step required for simple worker'",
    "dev": "wrangler dev",
    "deploy": "npx wrangler deploy -c cloudflare-workers/wrangler.toml",
    "tail": "wrangler tail",
    "test:integration": "vitest run tests/integration.test.js",
    "test": "npm run test:integration"
  },
  "devDependencies": {
    "jsdom": "^29.1.1",
    "vitest": "^2.1.9",
    "wrangler": "^4.95.0"
  }
}
