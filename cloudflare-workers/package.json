{
  "name": "axim-core-cloudflare-workers",
  "version": "1.0.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "description": "Cloudflare Workers for AXiM Core Edge Network Integration",
  "main": "src/index.js",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "npx wrangler deploy -c wrangler.toml",
    "dry-run": "npx wrangler deploy --dry-run -c wrangler.toml",
    "deploy:onyx": "npx wrangler deploy -c onyx-edge-worker/wrangler.toml",
    "dry-run:onyx": "npx wrangler deploy --dry-run -c onyx-edge-worker/wrangler.toml",
    "check": "npm run test && npm run dry-run && npm run dry-run:onyx",
    "tail": "wrangler tail",
    "test:integration": "vitest run tests/integration.test.js",
    "build": "echo \"No build step for cloudflare workers.\"",
    "test": "npm run test:integration"
  },
  "devDependencies": {
    "jsdom": "^29.1.1",
    "vitest": "^2.1.9",
    "wrangler": "^4.95.0"
  }
}