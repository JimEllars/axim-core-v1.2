{
  "name": "axim-core-dashboard",
  "private": true,
  "version": "1.1.0",
  "description": "AXiM Core Dashboard",
  "author": "AXiM",
  "type": "module",
  "main": "electron.cjs",
  "scripts": {
    "dev": "vite --port 5176 --strictPort",
    "build": "vite build",
    "build:cloud": "vite build",
    "lint": "eslint .",
    "lint:error": "eslint . --quiet",
    "preview": "npm run build && wrangler dev",
    "test": "vitest run --coverage",
    "electron:dev": "concurrently \"npm run dev\" \"electron .\"",
    "preelectron:build": "npm run lint",
    "electron:build": "npm run build && electron-builder --publish never",
    "electron:build:linux": "npm run build && electron-builder --linux --publish never",
    "electron:build:win": "npm run build && electron-builder --win --publish never",
    "electron:build:mac": "npm run build && electron-builder --mac --publish never",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google-cloud/pubsub": "^5.3.0",
    "@google-cloud/secret-manager": "^6.1.1",
    "@questlabs/react-sdk": "^2.2.898",
    "@supabase/supabase-js": "^2.78.0",
    "@tailwindcss/postcss": "^4.1.14",
    "axios": "^1.13.1",
    "compromise": "^14.14.4",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "echarts": "^5.6.0",
    "echarts-for-react": "^3.0.2",
    "electron-updater": "^6.6.2",
    "framer-motion": "^12.23.24",
    "js-cookie": "^3.0.5",
    "papaparse": "^5.5.3",
    "pg": "^8.16.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.5.0",
    "react-papaparse": "^4.4.0",
    "react-router-dom": "^6.30.3",
    "react-syntax-highlighter": "^16.1.0",
    "recharts": "^3.2.1",
    "redis": "^5.9.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.30.0",
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^3.2.4",
    "autoprefixer": "^10.4.20",
    "bcryptjs": "^3.0.3",
    "concurrently": "^9.2.1",
    "electron": "^38.5.0",
    "electron-builder": "24.13.3",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^16.4.0",
    "jsdom": "^27.1.0",
    "playwright": "^1.56.0",
    "postcss": "^8.4.49",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.1.14",
    "vite": "^7.1.9",
    "vitest": "^3.2.4",
    "wrangler": "^4.76.0"
  },
  "build": {
    "appId": "com.axim.core",
    "productName": "AXiM Core",
    "files": [
      "dist/**/*",
      "electron.cjs"
    ],
    "win": {
      "target": "nsis",
      "verifyUpdateCodeSignature": true
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "deleteAppDataOnUninstall": true
    },
    "publish": {
      "provider": "github"
    }
  }
}
